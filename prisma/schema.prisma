// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model - Core user entity
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String?
  slug          String?  @unique
  avatar        String? // Avatar for account (separate from profile avatar)
  phone         String?
  emailVerified Boolean  @default(false)
  role          UserRole @default(USER)
  accountStatus UserAccountStatus @default(ACTIVE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  profile                 UserProfile?
  experiences             UserExperience[]
  educations              UserEducation[]
  companies               CompanyMember[]
  applications            Application[]
  messages                Message[]
  follows                 Follow[]
  likes                   Like[]
  jobFavorites            JobFavorite[]
  posts                   Post[]
  postAuditLogs           PostAuditLog[]
  postReactions           PostReaction[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  postFavorites           PostFavorite[]
  socialAccounts          UserSocialAccount[]
  tickets                 CompanyTicket[]          @relation("TicketApplicant")
  ticketMessages          CompanyTicketMessage[]
  sentInvitations         CompanyInvitation[]      @relation("SentInvitations")
  notifications           Notification[]
  cvFlipConnections       CvFlipConnection[]
  cvFlipFlippedBy         CvFlipConnection[]       @relation("CvFlipFlippedBy")
  cvFlipRequestsReceived  CvFlipRequest[]          @relation("CvFlipRequestTarget")
  cvFlipRequestsSent      CvFlipRequest[]          @relation("CvFlipRequester")

  // Talent Pool
  talentPoolMember          TalentPoolMember?        @relation("TalentPoolMemberUser")
  talentPoolMembersAddedBy  TalentPoolMember[]       @relation("TalentPoolAddedBy")
  talentPoolRequests        TalentPoolRequest[]      @relation("TalentPoolRequestUser")
  talentPoolRequestsReviewed TalentPoolRequest[]     @relation("TalentPoolReviewedBy")
  talentPoolLogs            TalentPoolLog[]          @relation("TalentPoolLogUser")
  talentPoolLogsActed       TalentPoolLog[]          @relation("TalentPoolLogActor")
  courseEnrollments         CourseEnrollment[]

  @@index([slug])
  @@map("users")
}

// Email Verification Token
model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("email_verification_tokens")
}

// Password Reset Token
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

enum UserRole {
  USER
  ADMIN
}

enum UserAccountStatus {
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  OPEN_TO_WORK
  NOT_AVAILABLE
  LOOKING
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// UserProfile - Extended user information
model UserProfile {
  id       String   @id @default(cuid())
  userId   String   @unique
  avatar   String?
  headline String?
  bio      String?
  skills   String[]
  cvUrl    String?
  locations String[] @default([])
  /// Mã phường/xã canonical: `{provinceCode}/{officialWardCode}` — ví dụ `ha-noi/00004`
  wardCodes String[] @default([])
  website  String?
  linkedin String?
  github   String?

  // Contact info specific for CV/applications (independent from User.email/phone)
  contactEmail String?
  contactPhone String?

  // Profile-specific fields
  fullName   String? // Full name for CV/applications (separate from User.name)
  title      String?
  status     UserStatus?
  isPublic   Boolean     @default(true)
  isSearchingJob Boolean @default(true)
  allowCvFlip    Boolean @default(true)
  visibility Json? // { bio: boolean, experience: boolean, education: boolean, ksa: boolean, expectations: boolean }

  // KSA (Knowledge, Skills, Attitude)
  knowledge String[] // Array of knowledge items
  attitude  String[] // Array of attitude items

  // Expectations
  expectedSalaryMin Int?
  expectedSalaryMax Int?
  salaryCurrency    String?   @default("VND")
  workMode          String?
  expectedCulture   String?

  // Career Goals
  careerGoals String[]

  // Personal info for candidate filters
  gender        Gender?       @default(MALE)
  yearOfBirth  Int
  educationLevel EducationLevel?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// UserExperience - Work experience history
model UserExperience {
  id           String    @id @default(cuid())
  userId       String
  role         String
  company      String
  startDate    DateTime?
  endDate      DateTime?
  period       String? // Display string: "2019 - Hiện tại"
  desc         String?
  achievements String[]
  order        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([company])
  @@map("user_experiences")
}

// UserEducation - Education history
model UserEducation {
  id        String    @id @default(cuid())
  userId    String
  school    String
  degree    String
  startDate DateTime?
  endDate   DateTime?
  period    String? // Display string: "2015 - 2019"
  gpa       String?
  honors    String?
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([school])
  @@map("user_educations")
}

// Company model
model Company {
  id                       String                    @id @default(cuid())
  name                     String
  legalName                String?
  slug                     String                    @unique
  tagline                  String?
  description              String?
  logoUrl                  String?
  coverUrl                 String?
  website                  String?
  location                 String?
  wardCodes                String[]        @default([])
  email                    String?
  phone                    String?
  industry                 String?
  size                     String?
  foundedYear              Int?
  headcount                Int?
  headcountNote            String?
  metrics                  Json?
  profileStory             Json?
  highlights               Json?
  isVerified               Boolean                   @default(false)
  verificationStatus       CompanyVerificationStatus @default(UNVERIFIED)
  verificationFileKey      String?
  verificationFileUrl      String?
  verificationSubmittedAt  DateTime?
  verificationReviewedAt   DateTime?
  verificationReviewedById String?
  verificationRejectReason String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  // Relations
  profile     CompanyProfile?
  members     CompanyMember[]
  posts       Post[]
  jobs        Job[]
  follows     Follow[]
  tickets     CompanyTicket[]
  invitations CompanyInvitation[]

  // Verification & transparency modules
  verificationContacts CompanyVerificationContact[] @relation("CompanyToVerificationContacts")
  verificationLists    CompanyVerificationList[]    @relation("CompanyToVerificationLists")
  statements           CompanyStatement[]           @relation("CompanyToStatements")

  // Feature entitlements (premium features)
  featureEntitlements CompanyFeatureEntitlement[]
  cvFlipConnections   CvFlipConnection[]
  cvFlipRequests      CvFlipRequest[]
  cvFlipUsages        CvFlipUsage[]

  showcaseSlots CompanyShowcaseSlot[]

  @@map("companies")
}

/// Vị trí công ty trong danh sách nổi bật / hàng đầu (CMS homepage).
model CompanyShowcaseSlot {
  id               String                  @id @default(cuid())
  companyId        String
  company          Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  listType         CompanyShowcaseListType
  sortOrder        Int
  /// Chỉ dùng khi listType = FEATURED; cover riêng khác cover trang profile.
  featuredCoverUrl String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@unique([companyId, listType])
  @@index([listType, sortOrder])
  @@map("company_showcase_slots")
}

// New model for detailed Company Profile (Showcase)
model CompanyProfile {
  companyId String  @id
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Section: NHỮNG CON SỐ BIẾT NÓI
  stats Json? // [{ value, label, trend?, icon? }]

  // Section: TẦM NHÌN – SỨ MỆNH – GIÁ TRỊ CỐT LÕI
  vision     String? // Text
  mission    String? // Text
  coreValues String? // Text (semicolon separated or simple text)

  // Section: TRIẾT LÝ LÃNH ĐẠO (Leadership Philosophy)
  leadershipPhilosophy Json? // { media, mediaType, quote, author? }

  // Section: HỆ SINH THÁI SẢN PHẨM
  products Json? // { items: string[] } or [{ name, icon }]

  // Section: NGUYÊN TẮC TUYỂN DỤNG
  recruitmentPrinciples Json? // [{ title, desc, icon? }]

  // Section: PHÚC LỢI TOÀN DIỆN
  benefits Json? // { financial: [], nonFinancial: [] }

  // Section: HÀNH TRÌNH NHÂN SỰ
  hrJourney Json? // [{ step, title, desc }]

  // Section: LỘ TRÌNH THĂNG TIẾN
  careerPath Json? // { levels: string[] }

  // Section: CƠ CHẾ LƯƠNG & THƯỞNG
  salaryAndBonus Json? // { salary: [], bonus: [] }

  // Section: ĐÀO TẠO & PHÁT TRIỂN
  training Json? // { philosophy, programs: [], budget? }

  // Section: GALLERY (Hình ảnh & Video)
  gallery Json? // [{ url, type: 'image'|'video', caption? }]

  // Section: BAN LÃNH ĐẠO
  leaders Json? // [{ name, role, image, message, ... }]

  // Section: CÂU CHUYỆN & CỘT MỐC
  story Json? // { founderStory: { title, content, image? }, milestones: [] }

  // Section: VĂN HÓA (Testimonials, Typical Day)
  culture Json? // { testimonials: [], typicalDay: [] }

  // Section: GIẢI THƯỞNG
  awards Json? // [{ year, name, org }]

  // Section visibility control
  sectionVisibility Json? // { sectionKey: boolean } - Controls which sections are visible

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_profiles")
}

enum CompanyShowcaseListType {
  FEATURED
  TOP
}

enum CompanyVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

// CompanyMember - Many-to-many relationship between User and Company
model CompanyMember {
  id        String            @id @default(cuid())
  userId    String
  companyId String
  role      CompanyMemberRole @default(MEMBER)
  joinedAt  DateTime          @default(now())

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@map("company_members")
}

enum CompanyMemberRole {
  OWNER
  ADMIN
  MEMBER
}

// Post model - Company posts (Story posts)
model Post {
  id          String         @id @default(cuid())
  companyId   String
  createdById String?
  title       String
  content     String
  excerpt     String?
  coverUrl    String?
  type        PostType       @default(STORY)
  visibility  PostVisibility @default(PUBLIC)
  hiddenFromFeed Boolean     @default(false)
  deletedByJoyworkAt DateTime?
  deletedByJoyworkReason String?
  publishedAt DateTime?
  statementId String?
  statementSnapshot Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy     User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  statement     CompanyStatement? @relation(fields: [statementId], references: [id], onDelete: SetNull)
  likes         Like[]
  postReactions PostReaction[]
  images        PostImage[]
  auditLogs     PostAuditLog[]
  favorites     PostFavorite[]
  postJobs      PostJob[]
  hashtags      PostHashtag[]

  @@map("posts")
}

// Post images (gallery) - supports both images and videos
model PostImage {
  id         String    @id @default(cuid())
  postId     String
  url        String
  storageKey String?
  width      Int?
  height     Int?
  order      Int       @default(0)
  type       MediaType @default(IMAGE) // IMAGE or VIDEO

  // Relations
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_images")
}

enum MediaType {
  IMAGE
  VIDEO
}

model PostAuditLog {
  id        String          @id @default(cuid())
  postId    String?
  actorId   String?
  action    PostAuditAction
  metadata  Json?
  createdAt DateTime        @default(now())

  post  Post? @relation(fields: [postId], references: [id], onDelete: SetNull)
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@map("post_audit_logs")
}

// Link jobs to posts
model PostJob {
  id        String   @id @default(cuid())
  postId    String
  jobId     String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([postId, jobId])
  @@index([jobId])
  @@index([postId])
  @@map("post_jobs")
}

// Global hashtags for posts
model Hashtag {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  createdAt DateTime @default(now())

  // Relations
  posts PostHashtag[]

  @@map("hashtags")
}

// Link hashtags to posts (explicit many-to-many with timestamps)
model PostHashtag {
  id        String   @id @default(cuid())
  postId    String
  hashtagId String
  createdAt DateTime @default(now())

  // Relations
  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@unique([postId, hashtagId])
  @@index([hashtagId])
  @@index([postId])
  @@map("post_hashtags")
}

enum PostAuditAction {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  UNPUBLISH
}

enum PostType {
  STORY
  ANNOUNCEMENT
  EVENT
  STATEMENT
}

enum PostVisibility {
  PUBLIC
  PRIVATE
  DRAFT
}

// Job model - Job postings
model Job {
  id                  String          @id @default(cuid())
  companyId           String
  title               String
  slug                String?
  locations           String[]        @default([])
  wardCodes           String[]        @default([])
  remote              Boolean         @default(false)
  salaryMin           Int?
  salaryMax           Int?
  currency            String          @default("VND")
  employmentType      EmploymentType  @default(FULL_TIME)
  experienceLevel     ExperienceLevel @default(NO_EXPERIENCE)
  tags                String[]
  applicationDeadline DateTime?
  isActive            Boolean         @default(true)

  // Header fields
  department     String? // Bộ phận
  jobLevel       JobLevel? // Cấp bậc
  educationLevel EducationLevel? // Học vấn

  // JD chuẩn - Required fields
  generalInfo String @db.Text // "1. Thông tin chung" - markdown/rich text
  mission     String @db.Text // "2. Sứ mệnh/Vai trò" - markdown/rich text
  tasks       String @db.Text // "3. Nhiệm vụ chuyên môn" - markdown/rich text
  knowledge   String @db.Text // "5. Yêu cầu - Kiến thức" - markdown/rich text
  skills      String @db.Text // "5. Yêu cầu - Kỹ năng" - markdown/rich text
  attitude    String @db.Text // "5. Yêu cầu - Thái độ" - markdown/rich text

  // JD chuẩn - Optional fields
  kpis           String? @db.Text // "4. Kết quả chuyên môn" - markdown/rich text
  authority      String? @db.Text // "6. Quyền hạn" - markdown/rich text
  relationships  String? @db.Text // "7. Quan hệ công việc" - markdown/rich text
  careerPath     String? @db.Text // "8. Lộ trình phát triển" - markdown/rich text
  benefitsIncome String? // "9. Quyền lợi - Thu nhập" - plain text
  benefitsPerks  String? @db.Text // "9. Quyền lợi - Phúc lợi" - markdown/rich text
  contact        String? // Thông tin liên hệ - plain text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reminderSentAt DateTime?

  // Relations
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
  favorites    JobFavorite[]
  PostJob      PostJob[]

  @@index([slug])
  @@map("jobs")
}

// Job favorites - Saved jobs
model JobFavorite {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("job_favorites")
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum ExperienceLevel {
  NO_EXPERIENCE
  LT_1_YEAR
  Y1_2
  Y2_3
  Y3_5
  Y5_10
  GT_10
}

enum JobLevel {
  INTERN_STUDENT
  FRESH_GRAD
  EMPLOYEE
  SPECIALIST_TEAM_LEAD
  MANAGER_HEAD
  DIRECTOR
  EXECUTIVE
}

enum EducationLevel {
  NONE
  HIGH_SCHOOL
  COLLEGE
  BACHELOR
  MASTER
  PHD
  TRAINING_CENTER
}

// Application model - Job applications
model Application {
  id          String            @id @default(cuid())
  jobId       String
  userId      String
  status      ApplicationStatus @default(PENDING)
  coverLetter String?
  resumeUrl   String?
  notes       String?
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  job      Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([userId, jobId])
  @@map("applications")
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  REJECTED
  HIRED
}

// Message types for inbox
enum MessageType {
  TEXT
  FILE
  IMAGE
}

// Message model - Inbox messages
model Message {
  id            String      @id @default(cuid())
  applicationId String
  senderId      String
  content       String
  messageType   MessageType @default(TEXT)
  fileUrl       String?
  isRead        Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  sender      User        @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// Follow model - User follows Company
model Follow {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  createdAt DateTime @default(now())

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@map("follows")
}

// Like model - User likes Post
model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("likes")
}

enum ReactionType {
  JOY
  TRUST
  SKEPTIC
}

// Post reactions - Multi-reaction support
model PostReaction {
  id        String       @id @default(cuid())
  userId    String
  postId    String
  type      ReactionType
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId], name: "userId_postId")
  @@index([postId])
  @@map("post_reactions")
}

// Post favorites - Saved posts
model PostFavorite {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("post_favorites")
}

enum TicketStatus {
  OPEN
  RESPONDED
  CLOSED
}

model CompanyTicket {
  id                    String       @id @default(cuid())
  companyId             String
  applicantId           String
  title                 String
  status                TicketStatus @default(OPEN)
  applicantLastViewedAt DateTime?
  companyLastViewedAt   DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  company   Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applicant User                   @relation("TicketApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  messages  CompanyTicketMessage[]

  @@index([companyId])
  @@index([applicantId])
  @@index([status])
  @@map("company_tickets")
}

model CompanyTicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  senderId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticket CompanyTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([senderId])
  @@map("company_ticket_messages")
}

model CompanyInvitation {
  id        String            @id @default(cuid())
  email     String
  role      CompanyMemberRole
  token     String            @unique
  companyId String
  inviterId String
  expiresAt DateTime
  createdAt DateTime          @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inviter User    @relation("SentInvitations", fields: [inviterId], references: [id], onDelete: Cascade)

  @@unique([companyId, email])
  @@index([token])
  @@map("company_invitations")
}

// =========================
// Company Statements Verification (Transparency)
// =========================

model CompanyVerificationContact {
  id        String   @id @default(cuid())
  companyId String
  email     String
  name      String?
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    Company                       @relation("CompanyToVerificationContacts", fields: [companyId], references: [id], onDelete: Cascade)
  lists      CompanyVerificationListItem[]
  recipients CompanyStatementRecipient[]

  @@unique([companyId, email])
  @@map("company_verification_contacts")
}

model CompanyVerificationList {
  id        String   @id @default(cuid())
  companyId String
  name      String
  fileKey   String
  createdAt DateTime @default(now())

  company Company                       @relation("CompanyToVerificationLists", fields: [companyId], references: [id], onDelete: Cascade)
  items   CompanyVerificationListItem[]

  @@map("company_verification_lists")
}

model CompanyVerificationListItem {
  id        String @id @default(cuid())
  listId    String
  contactId String

  list    CompanyVerificationList    @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact CompanyVerificationContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listId, contactId])
  @@map("company_verification_list_items")
}

enum CompanyStatementStatus {
  DRAFT
  ACTIVE
  EXPIRED
}

model CompanyStatement {
  id          String                 @id @default(cuid())
  companyId   String
  title       String
  description String?
  isPublic    Boolean                @default(false)
  status      CompanyStatementStatus @default(DRAFT)
  sentAt      DateTime?
  expiresAt   DateTime?
  order       Int                    @default(0)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  company    Company                     @relation("CompanyToStatements", fields: [companyId], references: [id], onDelete: Cascade)
  recipients CompanyStatementRecipient[]
  posts      Post[]

  @@map("company_statements")
}

enum CompanyStatementAnswer {
  YES
  NO
}

model CompanyStatementRecipient {
  id          String                  @id @default(cuid())
  statementId String
  contactId   String
  sentAt      DateTime
  answer      CompanyStatementAnswer?
  verifiedAt  DateTime?

  statement CompanyStatement           @relation(fields: [statementId], references: [id], onDelete: Cascade)
  contact   CompanyVerificationContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([statementId, contactId])
  @@map("company_statement_recipients")
}

// Social login accounts (Google, Facebook, ...)
model UserSocialAccount {
  id         String   @id @default(cuid())
  userId     String
  provider   String // e.g. "google", "facebook"
  providerId String // sub/id from provider
  email      String? // email from provider (if available)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("user_social_accounts")
}

// Notification model - In-app notifications
model Notification {
  id                String           @id @default(cuid())
  userId            String
  type              NotificationType
  title             String
  content           String
  metadata          Json? // Additional data (e.g., ticketId, companyId, etc.)
  isRead            Boolean          @default(false)
  relatedEntityType String? // e.g., "TICKET", "APPLICATION", "JOB", etc.
  relatedEntityId   String? // ID of the related entity
  createdAt         DateTime         @default(now())
  readAt            DateTime?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([relatedEntityType, relatedEntityId])
  @@map("notifications")
}

enum NotificationType {
  TICKET_MESSAGE // New message in ticket
  TICKET_CREATED // New ticket created
  APPLICATION_STATUS // Application status changed
  JOB_APPLICATION // New job application
  COMPANY_FOLLOW // Someone followed company
  POST_LIKE // Post liked
  POST_COMMENT // Post commented
  SYSTEM // System notification
  CV_FLIP_REQUEST // Company requested CV flip approval
  CV_FLIP_APPROVED // Candidate approved CV flip request
  CV_FLIP_REJECTED // Candidate rejected CV flip request
}

enum CvFlipRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

// =========================
// Talent Pool
// =========================

enum TalentPoolMemberStatus {
  ACTIVE
  REMOVED
}

enum TalentPoolRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TalentPoolRequestSource {
  SELF_REQUEST
  ADMIN_ADD
}

enum TalentPoolLogAction {
  REQUEST_CREATED
  REQUEST_APPROVED
  REQUEST_REJECTED
  ADMIN_ADDED
  MEMBER_REMOVED
}

model TalentPoolMember {
  id        String                  @id @default(cuid())
  userId    String                  @unique
  status    TalentPoolMemberStatus  @default(ACTIVE)
  source    TalentPoolRequestSource
  addedById String?
  reason    String?
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  user    User  @relation("TalentPoolMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  addedBy User? @relation("TalentPoolAddedBy", fields: [addedById], references: [id], onDelete: SetNull)

  @@map("talent_pool_members")
}

model TalentPoolRequest {
  id           String                  @id @default(cuid())
  userId       String
  status       TalentPoolRequestStatus @default(PENDING)
  message      String?
  reason       String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  user       User  @relation("TalentPoolRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("TalentPoolReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@map("talent_pool_requests")
}

model TalentPoolLog {
  id        String              @id @default(cuid())
  userId    String
  actorId   String?
  action    TalentPoolLogAction
  metadata  Json?
  createdAt DateTime            @default(now())

  user  User  @relation("TalentPoolLogUser", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("TalentPoolLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("talent_pool_logs")
}

// =========================
// Company Feature Entitlements (Premium)
// =========================

model CompanyFeatureEntitlement {
  id         String    @id @default(cuid())
  companyId  String
  featureKey String
  enabled    Boolean   @default(true)
  metadata   Json?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, featureKey])
  @@index([companyId])
  @@map("company_feature_entitlements")
}

model CvFlipConnection {
  id          String   @id @default(cuid())
  companyId   String
  userId      String
  flippedById String
  flippedAt   DateTime @default(now())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  flippedBy User    @relation("CvFlipFlippedBy", fields: [flippedById], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
  @@map("cv_flip_connections")
}

model CvFlipRequest {
  id          String              @id @default(cuid())
  companyId   String
  userId      String
  requestedBy String
  status      CvFlipRequestStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime            @default(now())
  respondedAt DateTime?

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User    @relation("CvFlipRequestTarget", fields: [userId], references: [id], onDelete: Cascade)
  requester User    @relation("CvFlipRequester", fields: [requestedBy], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId, status])
  @@index([userId, status])
  @@map("cv_flip_requests")
}

model CvFlipUsage {
  id           String @id @default(cuid())
  companyId    String
  month        Int
  year         Int
  totalCount   Int    @default(0)
  requestCount Int    @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, month, year])
  @@map("cv_flip_usages")
}

model ProvinceRegistry {
  code          String   @id
  name          String
  type          String
  region        String
  merged        Boolean  @default(false)
  isActive      Boolean  @default(true)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  aliases ProvinceAlias[]
  wards   WardRegistry[]

  @@index([region])
  @@index([isActive])
  @@map("province_registry")
}

model ProvinceAlias {
  id           String   @id @default(cuid())
  provinceCode String
  aliasText    String
  aliasSlug    String
  aliasType    String   @default("MANUAL")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  province ProvinceRegistry @relation(fields: [provinceCode], references: [code], onDelete: Cascade)

  @@unique([provinceCode, aliasSlug])
  @@index([aliasSlug, isActive])
  @@index([provinceCode])
  @@map("province_aliases")
}

model WardRegistry {
  code         String   @id
  provinceCode String
  officialCode String
  name         String
  fullName     String?
  unitType     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  province ProvinceRegistry @relation(fields: [provinceCode], references: [code], onDelete: Cascade)

  @@unique([provinceCode, officialCode])
  @@index([provinceCode])
  @@map("ward_registry")
}

// =========================
// Online courses
// =========================

enum CourseVisibility {
  PUBLIC
  PRIVATE
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

enum CourseVideoSource {
  URL
  S3_KEY
}

enum CourseAttachmentSource {
  URL
  S3_KEY
}

model Course {
  id                String           @id @default(cuid())
  title             String
  slug              String           @unique
  shortDescription  String
  description       String?
  thumbnailUrl      String?
  visibility        CourseVisibility @default(PUBLIC)
  status            CourseStatus     @default(DRAFT)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  lessons      Lesson[]
  enrollments  CourseEnrollment[]

  @@index([status, visibility])
  @@index([slug])
  @@map("courses")
}

model Lesson {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course       Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  videos       LessonVideo[]
  attachments  LessonAttachment[]

  @@index([courseId])
  @@index([courseId, sortOrder])
  @@map("course_lessons")
}

model LessonVideo {
  id        String            @id @default(cuid())
  lessonId  String
  source    CourseVideoSource
  value     String
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([lessonId, sortOrder])
  @@map("course_lesson_videos")
}

model LessonAttachment {
  id        String                 @id @default(cuid())
  lessonId  String
  name      String
  source    CourseAttachmentSource
  value     String
  sortOrder Int                    @default(0)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([lessonId, sortOrder])
  @@map("course_lesson_attachments")
}

model CourseEnrollment {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([userId])
  @@map("course_enrollments")
}
