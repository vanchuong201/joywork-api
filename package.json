{
  "name": "joywork-api",
  "version": "1.0.0",
  "description": "JoyWork API - Platform connecting good companies with right people",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:provinces": "tsx prisma/seed-provinces.ts",
    "db:seed:wards": "tsx scripts/seed-wards-from-vn-units.ts",
    "db:studio": "prisma studio",
    "test:email": "tsx scripts/test-email.ts",
    "check:ses": "tsx scripts/check-ses-status.ts",
    "verify:email": "tsx scripts/verify-email.ts",
    "seed:jobs": "tsx scripts/seed-jobs.ts",
    "seed:candidates": "tsx scripts/seed-candidate-users.ts",
    "migrate:location-codes": "tsx scripts/migrate-location-codes.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "api",
    "fastify",
    "typescript",
    "prisma",
    "postgresql",
    "job-platform"
  ],
  "author": "JoyWork Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.681.0",
    "@aws-sdk/client-ses": "^3.936.0",
    "@aws-sdk/s3-request-presigner": "^3.681.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "@prisma/client": "6.18.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-label": "^2.1.8",
    "@sentry/node": "^10.49.0",
    "@types/nodemailer": "^7.0.4",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "fastify": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^7.0.10",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "slugify": "^1.6.9",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/busboy": "^1.5.4",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "html-entities": "^2.6.0",
    "prettier": "^3.1.1",
    "prisma": "6.18.0",
    "tsx": "^4.6.2",
    "typescript": "^5.9.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
